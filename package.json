{
  "name": "myst-review",
  "version": "0.0.1",
  "private": true,
  "description": "Desktop writing and research companion with inline AI commenting.",
  "author": "Myst Review",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --ext .ts,.tsx --cache",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\" \"*.{md,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html}\" \"*.{md,json}\""
  },
  "dependencies": {
    "@milkdown/kit": "^7.20.0",
    "@milkdown/react": "^7.20.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.2.0",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
